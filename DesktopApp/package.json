{
  "name": "anime-tracker-desktop",
  "version": "1.0.0",
  "description": "Desktop version of Anime Tracker",
  "author": "Noelia Soto",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.animetracker.desktop",
    "productName": "Anime Tracker",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "package.json",
      "build/icon.ico"
    ],
    "extraResources": [
      {
        "from": "../Backend/target/Backend-0.0.1-SNAPSHOT.jar",
        "to": "backend/Backend-0.0.1-SNAPSHOT.jar"
      },
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "signAndEditExecutable": true
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Anime Tracker",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^39.0.0",
    "electron-builder": "^26.8.1"
  }
}